<Window x:Class="DynamicIsland.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DynamicIsland"
        Title="DynamicIsland 设置"
        Width="420" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        Foreground="White"
        ShowInTaskbar="True">

    <Window.Resources>
        <!-- 分组卡片：浅色描边 + 内边距，深色主题下不刺眼 -->
        <Style x:Key="GroupCard" TargetType="Border">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18,16">

            <!-- 显示项：系统条 -->
            <Border Style="{StaticResource GroupCard}">
                <StackPanel>
                    <TextBlock Text="系统资源条显示项" Style="{StaticResource GroupTitle}"/>
                    <CheckBox Content="CPU" IsChecked="{Binding ShowCpu}"/>
                    <CheckBox Content="RAM (内存)" IsChecked="{Binding ShowRam}"/>
                    <CheckBox Content="GPU 使用率" IsChecked="{Binding ShowGpu}"/>
                    <CheckBox Content="VRAM (显存)" IsChecked="{Binding ShowVram}"/>
                    <CheckBox Content="NET (网速)" IsChecked="{Binding ShowNet}"/>
                </StackPanel>
            </Border>

            <!-- 阈值 -->
            <Border Style="{StaticResource GroupCard}">
                <StackPanel>
                    <TextBlock Text="点亮阈值" Style="{StaticResource GroupTitle}"/>
                    <TextBlock Text="CPU 或 RAM 超过阈值时，灵动岛收起态会点亮显示系统资源（否则让位时钟）。"
                               FontSize="11" Opacity="0.55" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CPU" FontSize="12" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="CpuSlider"
                                Minimum="20" Maximum="95"
                                Value="{Binding CpuActivate}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding CpuActivate, StringFormat={}{0:0}%}"
                                   FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="RAM" FontSize="12" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="RamSlider"
                                Minimum="30" Maximum="98"
                                Value="{Binding RamActivate}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding RamActivate, StringFormat={}{0:0}%}"
                                   FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 提醒开关 -->
            <Border Style="{StaticResource GroupCard}">
                <StackPanel>
                    <TextBlock Text="瞬时提醒" Style="{StaticResource GroupTitle}"/>
                    <CheckBox Content="电池/充电状态提醒（充电接入、拔下、低电量）"
                              IsChecked="{Binding EnableBatteryAlert}"/>
                    <CheckBox Content="截图/剪贴板图像提醒（Win+Shift+S 等）"
                              IsChecked="{Binding EnableClipboardAlert}"/>
                    <CheckBox Content="U 盘 / 可移动磁盘 连接断开提醒"
                              IsChecked="{Binding EnableUsbAlert}"/>
                    <CheckBox Content="蓝牙设备 连接断开提醒（耳机、键盘等）"
                              IsChecked="{Binding EnableBluetoothAlert}"/>
                    <CheckBox Content="网络 连接断开提醒（WiFi 连上、断网）"
                              IsChecked="{Binding EnableNetworkAlert}"/>
                    <CheckBox Content="下载完成提醒（监控 Downloads 文件夹）"
                              IsChecked="{Binding EnableDownloadAlert}"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding DownloadFolderPath}"
                                 FontSize="11" Height="24"
                                 Background="#1A1A1A" Foreground="White"
                                 BorderBrush="#44FFFFFF" BorderThickness="0.5"
                                 Padding="4,0"
                                 VerticalAlignment="Center"
                                 TextOptions.TextFormattingMode="Ideal"/>
                        <Button Grid.Column="1"
                                Content="浏览…"
                                Click="BrowseDownloadFolder_Click"
                                Height="24" Width="60"
                                Margin="6,0,0,0"
                                Background="#22FFFFFF" Foreground="White"
                                BorderBrush="#44FFFFFF" BorderThickness="0.5"
                                FontSize="11" Cursor="Hand"/>
                    </Grid>
                    <TextBlock Text="留空则自动检测系统 Downloads 文件夹"
                               FontSize="10" Opacity="0.5" Margin="2,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- 启动行为 -->
            <Border Style="{StaticResource GroupCard}">
                <StackPanel>
                    <TextBlock Text="启动行为" Style="{StaticResource GroupTitle}"/>
                    <TextBlock Text="开启后，登录 Windows 时自动启动 DynamicIsland。写入注册表 HKCU\…\Run，无需管理员权限。"
                               FontSize="11" Opacity="0.55" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <CheckBox x:Name="AutoStartCheck"
                              Content="开机时自动启动 DynamicIsland"
                              Checked="AutoStartCheck_Changed"
                              Unchecked="AutoStartCheck_Changed"/>
                </StackPanel>
            </Border>

            <!-- 行为 -->
            <Border Style="{StaticResource GroupCard}">
                <StackPanel>
                    <TextBlock Text="行为" Style="{StaticResource GroupTitle}"/>
                    <CheckBox Content="全屏应用时自动隐藏灵动岛（游戏、全屏视频等；有提醒时仍短暂弹出）"
                              IsChecked="{Binding EnableFullScreenSuppress}"/>
                    <CheckBox Content="同步提醒到 Windows 通知中心（全屏/离开时可回看）"
                              IsChecked="{Binding EnableSystemNotification}"/>
                </StackPanel>
            </Border>

            <!-- 显示位置：多显示器时选岛挂哪一块屏 -->
            <Border Style="{StaticResource GroupCard}">
                <StackPanel>
                    <TextBlock Text="显示位置" Style="{StaticResource GroupTitle}"/>
                    <TextBlock Text="选择灵动岛显示在哪一块显示器上（多屏可用）。"
                               FontSize="11" Opacity="0.55" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <ComboBox x:Name="MonitorCombo"
                              Background="#22FFFFFF" Foreground="White"
                              BorderBrush="#44FFFFFF" BorderThickness="0.5"
                              FontSize="12" Height="28"
                              SelectionChanged="MonitorCombo_SelectionChanged"/>
                </StackPanel>
            </Border>

            <!-- 关于 -->
            <Border Style="{StaticResource GroupCard}">
                <StackPanel>
                    <TextBlock Text="关于" Style="{StaticResource GroupTitle}"/>
                    <TextBlock Text="DynamicIsland" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="Windows WPF 灵动岛挂件" FontSize="11" Opacity="0.7" Margin="0,2,0,4"/>
                    <TextBlock Text="设置自动保存到 %AppData%\DynamicIsland\settings.json。" FontSize="10" Opacity="0.5"/>
                </StackPanel>
            </Border>

            <!-- 恢复默认：放最底防误触；按钮自带描边 hover 反馈 -->
            <Button x:Name="ResetButton" Content="恢复默认设置"
                    Click="ResetButton_Click"
                    Height="34" Margin="0,4,0,8"
                    Background="#22FFFFFF" Foreground="White"
                    BorderBrush="#44FFFFFF" BorderThickness="0.5"
                    FontSize="12" Cursor="Hand"/>

        </StackPanel>
    </ScrollViewer>
</Window>
