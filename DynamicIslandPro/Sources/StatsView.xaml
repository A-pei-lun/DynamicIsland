<UserControl x:Class="DynamicIslandPro.Sources.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:alerts="clr-namespace:DynamicIslandPro.Alerts"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <alerts:NullToCollapsedConverter x:Key="NullToCollapsed"/>
    </UserControl.Resources>

    <!-- 统计页：标题行（含概览 + 清空按钮）+ 列表。紧凑布局让列表拿到尽量多的垂直空间。
         前景色由 MainWindow TextElement.Foreground 穿透继承。 -->
    <Grid Margin="14,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题行：左=标题+概览，右=清空按钮（小尺寸，不占整行） -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="提醒统计"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Opacity="0.6"
                           VerticalAlignment="Center"/>
                <!-- 概览内嵌标题行：总数 · 天数，省掉独立大数字行腾空间给列表 -->
                <TextBlock x:Name="OverviewText"
                           FontSize="11"
                           Opacity="0.55"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>

            <!-- 清空按钮：挪到标题右侧，小尺寸不占整行 -->
            <Button x:Name="ClearButton"
                    Grid.Column="1"
                    Content="清空"
                    Click="ClearButton_Click"
                    FontSize="10"
                    Padding="8,2"
                    Cursor="Hand"
                    VerticalAlignment="Center">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="#1AFFFFFF"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextBlock.FontSize="10"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- 各类型条数列表：拿到标题行下全部剩余空间 -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="TypeList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#14FFFFFF"
                                CornerRadius="6"
                                Padding="8,4"
                                Margin="0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 类型名（英文前缀，小写） -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Key}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>

                                <!-- 次数 -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Value}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Opacity="0.8"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
