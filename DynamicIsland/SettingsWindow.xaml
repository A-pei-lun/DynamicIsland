<Window x:Class="DynamicIsland.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DynamicIsland"
        Title="设置"
        Width="780" Height="560"
        MinWidth="620" MinHeight="460"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SettingsWindowBg}"
        Foreground="{DynamicResource SettingsText}"
        ShowInTaskbar="True">

    <Window.Resources>
        <!-- 主题语义画刷：默认深色，ApplyTheme() 按 DisplaySettings.IsLight() 运行时覆写。
             DynamicResource 让所有引用即时联动。Win11 设置风格：实色卡片 + 强调色 + 细分割线。 -->
        <SolidColorBrush x:Key="SettingsWindowBg" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="SettingsNavBg" Color="#1F1F1F"/>
        <SolidColorBrush x:Key="SettingsText" Color="White"/>
        <SolidColorBrush x:Key="SettingsTextMuted" Color="#99FFFFFF"/>
        <SolidColorBrush x:Key="SettingsCardBg" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="SettingsCardBorder" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="SettingsControlBg" Color="#333333"/>
        <SolidColorBrush x:Key="SettingsControlBorder" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="SettingsInputBg" Color="#333333"/>
        <SolidColorBrush x:Key="SettingsPopupBg" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="SettingsAccent" Color="#4CC2FF"/>
        <SolidColorBrush x:Key="SettingsAccentSoft" Color="#334CC2FF"/>
        <SolidColorBrush x:Key="SettingsNavHoverBg" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="SettingsToggleOff" Color="#5C5C5C"/>
        <SolidColorBrush x:Key="SettingsTrackBg" Color="#3D3D3D"/>
        <SolidColorBrush x:Key="SettingsDivider" Color="#22FFFFFF"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 卡片：实色底 + 1px 细边 + 6px 圆角，内边距横向 16 -->
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SettingsCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,4"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- 卡片内一行：垂直内边距 11，底分割线（末行用 SettingRowLast 覆盖为 0） -->
        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="Padding" Value="0,11"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsDivider}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="SettingRowLast" TargetType="Border" BasedOn="{StaticResource SettingRow}">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="PageDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style x:Key="RowTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="RowDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- 侧边栏导航项：RadioButton 伪装；选中=强调色淡底 + 左侧强调色指示条 -->
        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource SettingsText}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <Grid Height="36">
                                <Rectangle x:Name="Indicator" Width="3" HorizontalAlignment="Left" Margin="6,8,0,8" RadiusX="1.5" RadiusY="1.5" Fill="{DynamicResource SettingsAccent}" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="22,0,12,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SettingsAccentSoft}"/>
                                <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SettingsNavHoverBg}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Win11 开关：40x20 药丸轨道 + 12px 圆拇指；开=强调色，关=灰 -->
        <Style x:Key="Win11Toggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" Background="{DynamicResource SettingsToggleOff}" CornerRadius="10"/>
                            <Border x:Name="Thumb" Width="12" Height="12" CornerRadius="6" Background="White" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource SettingsAccent}"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="24,0,0,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Win11 滑块：4px 细轨 + 强调色填充 + 16px 圆拇指 -->
        <Style x:Key="SliderFill" TargetType="RepeatButton">
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Height="4" CornerRadius="2" Background="{DynamicResource SettingsAccent}"/></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="SliderTrack" TargetType="RepeatButton">
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Height="4" CornerRadius="2" Background="Transparent"/></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="SliderThumb" TargetType="Thumb">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="8" Background="{DynamicResource SettingsAccent}" BorderBrush="{DynamicResource SettingsCardBg}" BorderThickness="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Win11Slider" TargetType="Slider">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="{DynamicResource SettingsTrackBg}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource SliderFill}"/></Track.DecreaseRepeatButton>
                                <Track.Thumb><Thumb Style="{StaticResource SliderThumb}"/></Track.Thumb>
                                <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource SliderTrack}"/></Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Win11 下拉框：扁平 + 圆角 + 雪佛兰；弹层主题化 -->
        <Style x:Key="Win11ComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource SettingsText}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource SettingsAccentSoft}"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource SettingsAccentSoft}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Win11ComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource SettingsText}"/>
            <Setter Property="Background" Value="{DynamicResource SettingsControlBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsControlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource Win11ComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"/>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border Background="Transparent"/></ControlTemplate></ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,28,0"/>
                            <Path Data="M0,0 L8,0 L4,5 Z" Fill="{TemplateBinding Foreground}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.6"/>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="{DynamicResource SettingsPopupBg}" BorderBrush="{DynamicResource SettingsControlBorder}" BorderThickness="1" CornerRadius="4" Padding="2" Margin="0,2,0,0" MaxHeight="320">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SettingsAccent}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Win11 按钮 / 输入框 -->
        <Style x:Key="Win11Button" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SettingsControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource SettingsText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsControlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource SettingsNavHoverBg}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource SettingsAccentSoft}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Win11Input" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SettingsInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource SettingsText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SettingsControlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{DynamicResource SettingsText}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource SettingsAccent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SettingsAccent}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0" Background="{DynamicResource SettingsNavBg}">
            <StackPanel Margin="0,14,0,0">
                <TextBlock Text="DynamicIsland" FontSize="12" FontWeight="SemiBold" Opacity="0.55" Margin="22,0,0,12"/>
                <RadioButton x:Name="NavAppearance" GroupName="Nav" IsChecked="True" Style="{StaticResource NavItem}" Content="外观"/>
                <RadioButton x:Name="NavDisplay" GroupName="Nav" Style="{StaticResource NavItem}" Content="显示"/>
                <RadioButton x:Name="NavAlerts" GroupName="Nav" Style="{StaticResource NavItem}" Content="提醒"/>
                <RadioButton x:Name="NavBehavior" GroupName="Nav" Style="{StaticResource NavItem}" Content="行为"/>
                <RadioButton x:Name="NavAbout" GroupName="Nav" Style="{StaticResource NavItem}" Content="关于"/>
            </StackPanel>
        </Border>

        <!-- 内容区：每页一个 ScrollViewer，Visibility 绑到对应导航项 IsChecked -->
        <Grid Grid.Column="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsChecked, ElementName=NavAppearance, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="28,20,28,24">
                    <TextBlock Text="外观" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="灵动岛背景材质、主题与模糊。亚克力模糊身后桌面；关模糊则锐利看穿；底色浓度调节材质深浅。" Style="{StaticResource PageDesc}"/>

                    <TextBlock Text="背景" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="材质" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="亚克力 / 全透明 / 云母平涂" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="BackdropCombo" Style="{StaticResource Win11ComboBox}" Width="160" SelectionChanged="BackdropCombo_SelectionChanged"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="主题" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="跟随系统 / 浅色 / 深色" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="ThemeCombo" Style="{StaticResource Win11ComboBox}" Width="160" SelectionChanged="ThemeCombo_SelectionChanged"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="模糊" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="开=亚克力模糊；关=锐利看穿(无模糊)。仅亚克力生效。" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="BlurToggle" Style="{StaticResource Win11Toggle}" IsChecked="{Binding BlurEnabled}"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowLast}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="底色浓度" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="材质底色深浅。系统亚克力模糊量固定，此值只调底色。" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <Slider Grid.Column="1" x:Name="BlurSlider" Style="{StaticResource Win11Slider}" Minimum="0" Maximum="100" Value="{Binding BlurIntensity}" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding BlurIntensity, StringFormat={}{0:0}%}" FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="液态玻璃（beta）" Style="{StaticResource SectionTitle}" Margin="0,4,0,6"/>
                    <Border x:Name="GlassCard" Style="{StaticResource SettingsCard}" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="自渲染可调模糊，实验性。排除截屏+抓身后桌面+WPF 模糊实现，比 DWM 亚克力更可控（半径/底色/帧率全可调）但耗 CPU。仅&quot;液态玻璃&quot;材质生效。" Style="{StaticResource RowDesc}" Margin="0,2,0,8"/>
                            <Border Style="{StaticResource SettingRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="模糊半径" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="身后桌面高斯模糊半径。DWM 亚克力模糊量固定不可调，液态玻璃自渲染才能调。越大越糊。" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <Slider Grid.Column="1" Style="{StaticResource Win11Slider}" Minimum="0" Maximum="100" Value="{Binding GlassBlurRadius}" TickFrequency="1" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding GlassBlurRadius, StringFormat={}{0:0}}" FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="底色浓度" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="玻璃叠层底色深浅。0≈无色全透，100=强底色。深色主题叠黑、浅色叠白。" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <Slider Grid.Column="1" Style="{StaticResource Win11Slider}" Minimum="0" Maximum="100" Value="{Binding GlassTintIntensity}" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding GlassTintIntensity, StringFormat={}{0:0}%}" FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="金边" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="顶部高光 + 底部阴影 + 描边，增强玻璃质感。" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding GlassEdgeEnabled}"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowLast}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="抓屏帧率" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="每秒抓身后桌面次数。越高越流畅越耗 CPU（BlurEffect 为 CPU 渲染）。" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <Slider Grid.Column="1" Style="{StaticResource Win11Slider}" Minimum="1" Maximum="60" Value="{Binding GlassCaptureFps}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding GlassCaptureFps, StringFormat={}{0:0}}" FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsChecked, ElementName=NavDisplay, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="28,20,28,24">
                    <TextBlock Text="显示" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="系统资源条显示项、点亮阈值与显示位置。" Style="{StaticResource PageDesc}"/>

                    <TextBlock Text="系统资源条" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="CPU 使用率" Style="{StaticResource RowTitle}" VerticalAlignment="Center"/><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding ShowCpu}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="RAM (内存)" Style="{StaticResource RowTitle}" VerticalAlignment="Center"/><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding ShowRam}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="GPU 使用率" Style="{StaticResource RowTitle}" VerticalAlignment="Center"/><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding ShowGpu}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="VRAM (显存)" Style="{StaticResource RowTitle}" VerticalAlignment="Center"/><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding ShowVram}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRowLast}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="NET (网速)" Style="{StaticResource RowTitle}" VerticalAlignment="Center"/><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding ShowNet}"/></Grid></Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="点亮阈值" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="CPU 或 RAM 超过阈值时，收起态点亮显示资源条（否则让位时钟）。退出阈值 = 点亮 − 10。" Style="{StaticResource RowDesc}" Margin="0,2,0,8"/>
                            <Border Style="{StaticResource SettingRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="CPU" Style="{StaticResource RowTitle}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="CpuSlider" Style="{StaticResource Win11Slider}" Minimum="20" Maximum="95" Value="{Binding CpuActivate}" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CpuActivate, StringFormat={}{0:0}%}" FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingRowLast}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="RAM" Style="{StaticResource RowTitle}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="RamSlider" Style="{StaticResource Win11Slider}" Minimum="30" Maximum="98" Value="{Binding RamActivate}" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RamActivate, StringFormat={}{0:0}%}" FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="显示位置" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingRowLast}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="显示器" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="选择灵动岛挂在哪一块屏（多屏可用）。" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="MonitorCombo" Style="{StaticResource Win11ComboBox}" Width="200" SelectionChanged="MonitorCombo_SelectionChanged"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsChecked, ElementName=NavAlerts, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="28,20,28,24">
                    <TextBlock Text="提醒" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="瞬时事件提醒开关与下载监控文件夹。" Style="{StaticResource PageDesc}"/>

                    <TextBlock Text="提醒类型" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" VerticalAlignment="Center"><TextBlock Text="电池 / 充电" Style="{StaticResource RowTitle}"/><TextBlock Text="充电接入、拔下、低电量" Style="{StaticResource RowDesc}"/></StackPanel><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding EnableBatteryAlert}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" VerticalAlignment="Center"><TextBlock Text="剪贴板图像" Style="{StaticResource RowTitle}"/><TextBlock Text="Win+Shift+S 截图等" Style="{StaticResource RowDesc}"/></StackPanel><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding EnableClipboardAlert}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" VerticalAlignment="Center"><TextBlock Text="U 盘 / 可移动磁盘" Style="{StaticResource RowTitle}"/><TextBlock Text="连接 / 断开" Style="{StaticResource RowDesc}"/></StackPanel><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding EnableUsbAlert}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" VerticalAlignment="Center"><TextBlock Text="蓝牙设备" Style="{StaticResource RowTitle}"/><TextBlock Text="耳机、键盘等连接 / 断开" Style="{StaticResource RowDesc}"/></StackPanel><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding EnableBluetoothAlert}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" VerticalAlignment="Center"><TextBlock Text="网络" Style="{StaticResource RowTitle}"/><TextBlock Text="WiFi 连上 / 断网" Style="{StaticResource RowDesc}"/></StackPanel><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding EnableNetworkAlert}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRowLast}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" VerticalAlignment="Center"><TextBlock Text="下载完成" Style="{StaticResource RowTitle}"/><TextBlock Text="监控 Downloads 文件夹" Style="{StaticResource RowDesc}"/></StackPanel><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding EnableDownloadAlert}"/></Grid></Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="下载监控文件夹" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingRowLast}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="DownloadFolderBox" Style="{StaticResource Win11Input}" Text="{Binding DownloadFolderPath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="浏览…" Style="{StaticResource Win11Button}" Click="BrowseDownloadFolder_Click" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="留空则自动检测系统 Downloads 文件夹" Style="{StaticResource RowDesc}" Margin="0,8,0,2"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsChecked, ElementName=NavBehavior, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="28,20,28,24">
                    <TextBlock Text="行为" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="启动、全屏与通知行为。" Style="{StaticResource PageDesc}"/>

                    <TextBlock Text="系统" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" VerticalAlignment="Center"><TextBlock Text="开机自启动" Style="{StaticResource RowTitle}"/><TextBlock Text="登录 Windows 时自动启动。写注册表 HKCU\…\Run。" Style="{StaticResource RowDesc}"/></StackPanel><ToggleButton Grid.Column="1" x:Name="AutoStartCheck" Style="{StaticResource Win11Toggle}" Checked="AutoStartCheck_Changed" Unchecked="AutoStartCheck_Changed"/></Grid></Border>
                            <Border Style="{StaticResource SettingRow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" VerticalAlignment="Center"><TextBlock Text="全屏时自动隐藏" Style="{StaticResource RowTitle}"/><TextBlock Text="游戏 / 全屏视频覆盖所在屏时隐藏；有提醒仍短暂弹出。" Style="{StaticResource RowDesc}"/></StackPanel><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding EnableFullScreenSuppress}"/></Grid></Border>
                            <Border Style="{StaticResource SettingRowLast}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" VerticalAlignment="Center"><TextBlock Text="同步到通知中心" Style="{StaticResource RowTitle}"/><TextBlock Text="提醒同步发到 Windows 通知中心，可回看。" Style="{StaticResource RowDesc}"/></StackPanel><ToggleButton Grid.Column="1" Style="{StaticResource Win11Toggle}" IsChecked="{Binding EnableSystemNotification}"/></Grid></Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsChecked, ElementName=NavAbout, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="28,20,28,24">
                    <TextBlock Text="关于" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="版本与重置。" Style="{StaticResource PageDesc}"/>

                    <TextBlock Text="应用" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel Margin="0,4">
                            <TextBlock Text="DynamicIsland" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Windows WPF 灵动岛挂件" FontSize="12" Opacity="0.7" Margin="0,2,0,6"/>
                            <TextBlock Text="设置自动保存到 %AppData%\DynamicIsland\settings.json" FontSize="11" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="重置" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingRowLast}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="恢复默认设置" Style="{StaticResource RowTitle}"/>
                                        <TextBlock Text="重置所有显示项、阈值与提醒开关。" Style="{StaticResource RowDesc}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="ResetButton" Content="恢复" Style="{StaticResource Win11Button}" Click="ResetButton_Click" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
