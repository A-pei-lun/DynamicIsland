<UserControl x:Class="DynamicIslandPro.Alerts.NotificationListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:alerts="clr-namespace:DynamicIslandPro.Alerts"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <alerts:NullToCollapsedConverter x:Key="NullToCollapsed"/>
    </UserControl.Resources>

    <!-- 最近通知列表：竖排，每条 [图标]+[标题/副标题]+[相对时间]。
         高度受限走 ScrollViewer，前景色由 MainWindow TextElement.Foreground 穿透继承。 -->
    <Grid Margin="14,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="最近通知"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Opacity="0.6"
                   Margin="2,0,0,6"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="List">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#14FFFFFF"
                                CornerRadius="6"
                                Padding="8,5"
                                Margin="0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 图标 -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Icon}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Visibility="{Binding Icon, Converter={StaticResource NullToCollapsed}}"/>

                                <!-- 标题 + 副标题 + 动作按钮 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Subtitle}"
                                               FontSize="10"
                                               Opacity="0.55"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Subtitle, Converter={StaticResource NullToCollapsed}}"/>
                                </StackPanel>

                                <!-- 右侧：动作按钮（非 null 显示）+ 相对时间 -->
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                    <!-- 动作按钮：下载完成等可重新执行的动作。绑 Action.Label，非 null 显示 -->
                                    <Button Content="{Binding Action.Label}"
                                            Click="ItemAction_Click"
                                            FontSize="10"
                                            Padding="8,1"
                                            Margin="0,0,8,0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding Action, Converter={StaticResource NullToCollapsed}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd"
                                                                    Background="#1AFFFFFF"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  TextBlock.FontSize="10"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- 相对时间 -->
                                    <TextBlock Text="{Binding RelativeTime}"
                                               FontSize="10"
                                               Opacity="0.45"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 空状态：常驻页历史为空时给个提示，免得翻到空白页莫名其妙 -->
        <TextBlock x:Name="EmptyHint"
                   Grid.Row="1"
                   Text="📭 暂无通知"
                   FontSize="13"
                   Opacity="0.45"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>
