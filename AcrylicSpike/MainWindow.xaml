<Window x:Class="AcrylicSpike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AcrylicSpike — 1/2/3/4 切换, Esc 退出"
        Width="360" Height="72"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <!-- 与主程序同构：AllowsTransparency=False + Background=Transparent + CompositionTarget 置透明，
         让 DWM 材质透出；圆角交系统。此 spike 用来实锤 Mica/Transparent 的渲染表现。 -->
    <Grid>
        <TextBlock x:Name="ModeLabel"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="White"
                   FontSize="12"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Text="启动中…"/>
    </Grid>
</Window>
