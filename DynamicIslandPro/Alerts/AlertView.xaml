<UserControl x:Class="DynamicIslandPro.Alerts.AlertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DynamicIslandPro.Alerts"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToCollapsedConverter x:Key="NullToCollapsed"/>
    </UserControl.Resources>

    <!-- 单行提醒胶囊：图标 + 标题/副标题 + 可选动作按钮。前景色由 MainWindow 的 TextElement.Foreground 穿透继承。
         心跳 Scale 动画由 MainWindow 通过 RenderTransform 驱动。 -->
    <Grid x:Name="HeartbeatGrid" Margin="16,0"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Icon}"
                   FontSize="18"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   Visibility="{Binding Icon, Converter={StaticResource NullToCollapsed}}"/>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center">
            <TextBlock Text="{Binding Title}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding Subtitle}"
                       FontSize="11"
                       Opacity="0.6"
                       TextTrimming="CharacterEllipsis"
                       Visibility="{Binding Subtitle, Converter={StaticResource NullToCollapsed}}"/>
        </StackPanel>

        <!-- 动作按钮（下载完成→打开 等）。绑 Action，非 null 才显示。点击执行回调并关闭提醒。 -->
        <Button x:Name="ActionButton"
                Grid.Column="2"
                Content="{Binding Action.Label}"
                Click="ActionButton_Click"
                FontSize="12"
                Padding="10,2"
                Margin="10,0,0,0"
                Cursor="Hand"
                VerticalAlignment="Center"
                Visibility="{Binding Action, Converter={StaticResource NullToCollapsed}}">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="#1AFFFFFF"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextBlock.FontSize="12"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <!-- 高光扫过（Alert 出现时从左到右闪一次）。默认透明，背景由 code-behind 构建。
             放最后、跨三列盖住所有内容，不阻挡交互。 -->
        <Border x:Name="SweepLight"
                Grid.ColumnSpan="3"
                IsHitTestVisible="False"
                Opacity="0"/>
    </Grid>
</UserControl>
