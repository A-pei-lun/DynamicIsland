<Window x:Class="D3D11D3D9D3DImage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="D3D11D3D9D3DImage"
        Width="640" Height="500" Background="#1E1E1E"
        Loaded="OnLoaded" Closing="OnClosing" KeyDown="OnKeyDown">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />   <!-- 标题 + 模式 -->
      <RowDefinition Height="Auto" />   <!-- 期望颜色 -->
      <RowDefinition Height="*" />      <!-- D3DImage -->
      <RowDefinition Height="Auto" />   <!-- 次数 + 状态 -->
    </Grid.RowDefinitions>

    <!-- 标题行 -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
      <TextBlock x:Name="ModeBlock" Text="M3: d3d9-local"
                 FontSize="12" Foreground="#888" VerticalAlignment="Center" />
      <TextBlock Text="  |  " Foreground="#444" VerticalAlignment="Center" />
      <TextBlock x:Name="TitleBlock" Text="D3D9Ex 本地 surface → D3DImage"
                 FontSize="13" Foreground="#CCC" VerticalAlignment="Center" />
    </StackPanel>

    <!-- 期望颜色标签 -->
    <Border Grid.Row="1" Background="#2A2A2A" CornerRadius="4" Padding="8,6" Margin="0,0,0,6">
      <TextBlock x:Name="ExpectedColorBlock"
                 Text="期望颜色：—"
                 FontSize="16" FontWeight="Bold" Foreground="White"
                 HorizontalAlignment="Center" />
    </Border>

    <!-- D3DImage 区域 -->
    <Border Grid.Row="2" BorderBrush="#555" BorderThickness="1"
            Background="#0A0A0A" CornerRadius="2">
      <Image x:Name="D3DImageHost" Stretch="Uniform" />
    </Border>

    <!-- 底部状态 -->
    <StackPanel Grid.Row="3" Margin="0,6,0,0">
      <TextBlock x:Name="CountBlock"
                 Text="第 0/12 次"
                 FontSize="12" Foreground="#999" HorizontalAlignment="Center" />
      <TextBlock x:Name="StatusBlock"
                 Text="初始化中..."
                 FontSize="11" Foreground="#999" HorizontalAlignment="Center" />
    </StackPanel>
  </Grid>
</Window>