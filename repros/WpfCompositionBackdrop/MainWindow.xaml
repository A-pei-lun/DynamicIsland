<Window x:Class="WpfCompositionBackdrop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WpfCompositionBackdrop — M5: red SpriteVisual"
        Width="800" Height="600"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent"
        Loaded="OnLoaded" Closing="OnClosing" KeyDown="OnKeyDown">
  <Grid Margin="20">
    <!-- WPF 控件位于红色 SpriteVisual 上方 -->
    <TextBlock Text="WPF TextBlock — white text on red background"
               Foreground="White" FontSize="18" FontWeight="Bold"
               VerticalAlignment="Top" HorizontalAlignment="Center" />

    <Button Content="Green Button"
            Background="Green" Foreground="White" FontSize="14"
            Width="160" Height="40"
            HorizontalAlignment="Center" VerticalAlignment="Center" />

    <Border BorderBrush="White" BorderThickness="3" CornerRadius="8"
            Width="200" Height="100"
            HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40">
      <TextBlock Text="Bordered Area" Foreground="White"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Border>

    <!-- 状态栏 -->
    <TextBlock x:Name="StatusBlock" Text="初始化中..."
               FontSize="11" Foreground="#999"
               HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" />
  </Grid>
</Window>