<Window x:Class="DynamicIsland.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DynamicIsland"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DynamicIsland"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        Topmost="True"
        Width="200"
        Height="40"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.ContextMenu>
        <ContextMenu Opened="OnContextMenuOpened" Closed="OnContextMenuClosed">
            <MenuItem Header="设置…" Click="OpenSettings_Click"/>
            <MenuItem Header="测试提醒" Click="TestAlert_Click"/>
            <MenuItem Header="测试打断" Click="TestInterrupt_Click"/>
            <MenuItem Header="测试动作提醒" Click="TestActionAlert_Click"/>
            <Separator/>
            <MenuItem Header="退出" Click="Exit_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Border x:Name="GlassBorder"
            CornerRadius="20"
            BorderThickness="0.5"
            Background="#BF1A1A1A"
            BorderBrush="#33FFFFFF">
        <Grid x:Name="RootGrid">
            <!-- 液态玻璃自渲染层（仅 LiquidGlass 模式显示，由 LiquidGlassRenderer 驱动）：
                 GlassCapture=抓到的"窗后桌面"+可调半径高斯模糊；GlassTint=底色叠层。
                 放最底层，GlassBorder 圆角裁剪到胶囊形。 -->
            <Image x:Name="GlassCapture" Stretch="Fill" Visibility="Collapsed">
                <Image.Effect>
                    <BlurEffect x:Name="GlassBlur" Radius="22"/>
                </Image.Effect>
            </Image>
            <Border x:Name="GlassTint" Background="Transparent" Visibility="Collapsed"/>

            <!-- 顶部高光（初始 Opacity 由 code-behind 的 HighlightBaseOpacity 设定，hover 时增亮） -->
            <Border x:Name="TopHighlight"
                    Height="16"
                    VerticalAlignment="Top"
                    Margin="8,2,8,0"
                    CornerRadius="10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#44FFFFFF" Offset="0"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- 底部微光 -->
            <Border x:Name="BottomHighlight"
                    Height="10"
                    VerticalAlignment="Bottom"
                    Margin="8,0,8,2"
                    CornerRadius="5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- 状态文字（收起/悬停态）。用 MarqueeText：长歌名超出可视宽时自动横向滚动。
                 MaxWidth 由 code-behind 按当前状态宽动态设定，给溢出判定一个有限基准。 -->
            <local:MarqueeText x:Name="StatusText"
                       Text="🕒 --:--"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <!-- 展开态自定义视图宿主（仅当 source 提供 ExpandedView 时显示） -->
            <ContentControl x:Name="ExpandedHost"
                            Visibility="Collapsed"
                            Focusable="False"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>

            <!-- 瞬时提醒宿主：alert 激活时显示 AlertView，优先级高于 ExpandedHost/StatusText -->
            <ContentControl x:Name="AlertSlot"
                            Visibility="Collapsed"
                            Focusable="False"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
