<UserControl x:Class="DynamicIslandPro.IslandDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DynamicIslandPro"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 指标胶囊：单色克制（GPT #6 不按指标上色），轻量高光提升产品感而非监控软件感。
             圆角小尺寸内嵌元素，在 Layered 透明窗内安全渲染（非窗口级浅色方块）。 -->
        <Style x:Key="MetricPill" TargetType="Border">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="Margin" Value="3,0"/>
        </Style>
    </UserControl.Resources>

    <!-- 展开态组合仪表盘：上=分页面板区（滚轮翻页），中=页指示点，下=固定系统资源条。
         内部一切随 MainWindow 的 RootGrid LayoutTransform 整体缩放。 -->
    <!-- PreviewMouseWheel（隧道事件）：在内部 ScrollViewer（通知页/统计页列表）吞掉 wheel 前
         先到根 Grid，保证滚轮始终翻页不被列表拦截。e.Handled=true 阻止 ScrollViewer 自滚。 -->
    <Grid PreviewMouseWheel="OnWheel" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 分页面板区：一次只显示一个 panel 的 View -->
        <ContentControl x:Name="PageHost"
                        Grid.Row="0"
                        Focusable="False"
                        ClipToBounds="True"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>

        <!-- 空状态：无可用面板（如无媒体会话）时的占位 -->
        <TextBlock x:Name="EmptyHint"
                   Grid.Row="0"
                   Text="🕊 暂无信息"
                   FontSize="14"
                   Opacity="0.5"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <!-- 页指示点：随可用页数量动态重建，当前页高亮 -->
        <StackPanel x:Name="DotsHost"
                    Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,2,0,4"/>

        <!-- 固定系统资源条：永远显示，不参与翻页。
             DataContext=SystemResourceSource（数值）+ DisplaySettings.Instance（显隐）。
             英文缩写：CPU/RAM/GPU/VRAM/NET，每项可独立显隐。显隐设置在设置窗里改。 -->
        <Border x:Name="SystemStrip" Grid.Row="2"
                Padding="0,5,0,2"
                BorderThickness="0,0.5,0,0" BorderBrush="#33FFFFFF">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Style="{StaticResource MetricPill}"
                        Visibility="{Binding ShowCpu, Source={x:Static local:DisplaySettings.Instance}, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="CPU" FontSize="10" Opacity="0.55" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding Cpu, StringFormat={}{0:0}%}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricPill}"
                        Visibility="{Binding ShowRam, Source={x:Static local:DisplaySettings.Instance}, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="RAM" FontSize="10" Opacity="0.55" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding Ram, StringFormat={}{0:0}%}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricPill}"
                        Visibility="{Binding ShowGpu, Source={x:Static local:DisplaySettings.Instance}, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="GPU" FontSize="10" Opacity="0.55" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding GpuText}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricPill}"
                        Visibility="{Binding ShowVram, Source={x:Static local:DisplaySettings.Instance}, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="VRAM" FontSize="10" Opacity="0.55" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding GpuVramText}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricPill}"
                        Visibility="{Binding ShowNet, Source={x:Static local:DisplaySettings.Instance}, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="NET" FontSize="10" Opacity="0.55" Margin="0,0,4,0"/>
                        <TextBlock Text="↓" FontSize="11" Margin="0,0,2,0"/>
                        <TextBlock Text="{Binding DownRateText}" FontSize="11"/>
                        <TextBlock Text="↑" FontSize="11" Margin="5,0,2,0"/>
                        <TextBlock Text="{Binding UpRateText}" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
